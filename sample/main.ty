namespace main

struct Popcount {
  ar: [Int32],
}

impl Popcount {
  fn check(self, even: Int32) -> Int32 {
    let ch: ref chan<Int32> = chan<Int32>();
    let mut sent = 0;
    for x in self.ar {
      conc {
        printf("Try %d\r\n", x);
        let n = match (x & even) {
          x => 1
          _ => 0
        }
        ch.send(n);
      }
      sent += 1;
    }

    let mut count = 0;
    while sent > 0 {
      let value = ch.recv();
      count += value;
      sent -= 1;
    }
    return count;
  }
}

fn main() -> Int32 {
  let p: Popcount = Popcount {
    ar: [1, 2, 4, 8, 16, 32],
  }
  let n = p.check(15);
  printf("Result: %d\r\n", n);
  return 0;
}
